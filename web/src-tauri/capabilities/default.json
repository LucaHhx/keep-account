{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "记账本默认权限配置",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:window:allow-start-dragging",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" }
      ]
    }
  ],
  "platforms": ["linux", "macOS", "windows", "iOS", "android"]
}
